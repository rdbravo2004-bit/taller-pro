      "id": "call-reminders",
      "name": "Generar recordatorios",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [450, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extraer cada recordatorio para enviar individualmente\nconst data = $input.first().json;\n\nif (data.reminders_generated === 0) {\n  return []; // No hay recordatorios, terminar\n}\n\nreturn data.results.map(r => ({\n  phone: r.phone,\n  message: r.message,\n  status: r.status\n}));"
      },
      "id": "split-reminders",
      "name": "Separar recordatorios",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "condition-phone",
              "leftValue": "={{ $json.phone }}",
              "rightValue": "—",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "filter-phone",
      "name": "Tiene teléfono?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "url": "https://graph.facebook.com/v19.0/1022623927610993/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer "
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "messaging_product",
              "value": "whatsapp"
            },
            {
              "name": "to",
              "value": "={{ $json.phone }}"
            },
            {
              "name": "type",
              "value": "text"
            },
            {
              "name": "text.body",
              "value": "={{ $json.message.replace('...', '') }}"
            }
          ]
        },
        "options": {}
      },
      "id": "send-whatsapp",
      "name": "Enviar WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1050, 300]
    }
  ],
  "connections": {
    "Cada día 18:00": {
      "main": [[{ "node": "Generar recordatorios", "type": "main", "index": 0 }]]
    },
    "Generar recordatorios": {
      "main": [[{ "node": "Separar recordatorios", "type": "main", "index": 0 }]]
    },
    "Separar recordatorios": {
      "main": [[{ "node": "Tiene teléfono?", "type": "main", "index": 0 }]]
    },
    "Tiene teléfono?": {
      "main": [
        [{ "node": "Enviar WhatsApp", "type": "main", "index": 0 }],
        []
      ]
    }
  },
  "settings": {
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "tags": [{ "name": "taller-pro" }],
